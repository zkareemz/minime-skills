{
  "name": "minime-skills",
  "version": "0.2.2",
  "description": "A universal AI skills framework for Claude Code, Cursor, Copilot, Gemini, Codex, and more",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "minime-skills": "dist/bin/minime.js"
  },
  "files": [
    "dist",
    "skills",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsx bin/minime.ts",
    "format": "prettier --write \"src/**/*.ts\" \"bin/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "release": "node scripts/release.mjs"
  },
  "keywords": [
    "ai",
    "skills",
    "claude",
    "cursor",
    "copilot",
    "gemini",
    "codex",
    "agents"
  ],
  "author": "zkareemz <kareem.cs@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zkareemz/minime-skills.git"
  },
  "homepage": "https://github.com/zkareemz/minime-skills#readme",
  "bugs": {
    "url": "https://github.com/zkareemz/minime-skills/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/fs-extra": "^11.0.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.8.3",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@clack/prompts": "^1.4.0",
    "commander": "^12.0.0",
    "fs-extra": "^11.0.0",
    "gray-matter": "^4.0.0"
  }
}
